PORT=4000
API_BASE_URL=http://localhost:4000
PUBLIC_API_BASE_URL=http://localhost:4000
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/media_downloads
# API_TOKEN=change-me
STORAGE_DIR=packages/backend/storage
MAX_CONCURRENT_DOWNLOADS=2

# Server-side personal YouTube cookies (Netscape cookies.txt format). When set,
# the backend materializes /tmp/yt-dlp-cookies.txt on startup and forwards it
# to every yt-dlp invocation via --cookies. Never logged, never exposed to
# clients. Leave empty to run in anonymous mode.
# YOUTUBE_COOKIES=

# Proxy routing — use when the server's IP is blocked by YouTube.
# Never logged, never exposed to clients.
#
# Option A: single proxy
# YOUTUBE_PROXY=http://host:port
# YOUTUBE_PROXY=http://user:pass@host:port
#
# Option B: multiple proxies (one per line, randomly rotated).
# Analyze retries will rotate through them automatically.
# PROXY_LIST=http://host1:port
# PROXY_LIST=http://user:pass@host2:port

# YouTube extractor: player clients to use for bypassing bot detection.
# Defaults to `android`, which is the most reliable single client as of
# late 2025/early 2026 (mweb/tv_embedded increasingly return HTTP 429 or
# fail the n-challenge). If the primary client fails, the backend retries
# once with `YT_FALLBACK_PLAYER_CLIENTS` (default `web`) before giving up.
# Known clients: web, android, web_safari, android_music, tv, tv_embedded
# YT_PLAYER_CLIENTS=android
# YT_FALLBACK_PLAYER_CLIENTS=web

# Throttle download speed to avoid rate limiting (e.g. 100K, 1M)
# YT_THROTTLED_RATE=100K

# Space out yt-dlp HTTP requests so YouTube doesn't rate-limit us. Each
# request sleeps 2-5s, with a guaranteed 1s pause between consecutive
# requests. Tweak if you see HTTP 429 in the backend logs.
# YT_SLEEP_INTERVAL=2
# YT_MAX_SLEEP_INTERVAL=5
# YT_SLEEP_REQUESTS=1

# Security
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
ANALYZE_TIMEOUT_MS=60000
DOWNLOAD_TIMEOUT_MS=600000
