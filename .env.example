PORT=4000
API_BASE_URL=http://localhost:4000
PUBLIC_API_BASE_URL=http://localhost:4000
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/media_downloads
# API_TOKEN=change-me
STORAGE_DIR=packages/backend/storage
MAX_CONCURRENT_DOWNLOADS=2

# Server-side personal YouTube cookies (Netscape cookies.txt format). When set,
# the backend materializes /tmp/yt-dlp-cookies.txt on startup and forwards it
# to every yt-dlp invocation via --cookies. Never logged, never exposed to
# clients. Leave empty to run in anonymous mode.
# YOUTUBE_COOKIES=

# YouTube extractor: player clients to use for bypassing bot detection.
# Multiple clients separated by commas give yt-dlp fallback options.
# Known clients: web, android, web_safari, android_music, tv, tv_embedded
# YT_PLAYER_CLIENTS=web,android

# Throttle download speed to avoid rate limiting (e.g. 100K, 1M)
# YT_THROTTLED_RATE=100K

# Security
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
ANALYZE_TIMEOUT_MS=30000
DOWNLOAD_TIMEOUT_MS=600000
