{
  "expo": {
    "name": "Media Download Manager",
    "slug": "media-download-manager",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Save downloaded videos and audio files to your media library."
      }
    },
    "android": {
      "permissions": [
        "READ_MEDIA_AUDIO",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    }
  }
}

